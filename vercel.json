{
  "version": 2,
  "installCommand": "npm install && npm install --prefix front",
  "buildCommand": "npm run build",
  "outputDirectory": "front/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
